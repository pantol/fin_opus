# Copy to .env and fill in what you need: `cp .env.example .env`
# The CLI auto-loads this file; anything already exported in your shell wins.
# All variables are OPTIONAL — every feature degrades gracefully when unset.
# .env is .gitignored — never commit real secrets.

# --- Telegram alerts (check-data / status / LLM budget cap) ---
# Without a token+chat_id, alerts run in dry-run mode (printed to the console).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- LLM features, Phase 2+ (only `make llm` / `make eval-llm`) ---
# The LLM is NOT used in Phases 0+1 or anywhere in the money/risk path.
OPENROUTER_API_KEY=

# --- Backups: snapshot upload to Cloudflare R2 (only `make backup`) ---
# Without these, backups stay local-only. Needs the extra: pip install -e ".[backup]"
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# --- Dead-man's-switch health pings (healthchecks.io-style; optional) ---
# Pinged after each healthy collector cycle / successful backup. Silent no-op if unset.
HEALTHCHECK_URL_COLLECT=
HEALTHCHECK_URL_BACKUP=
